program = { SOI ~ statement* ~ EOI }

statement = { ((function_call | macro_call) ~ ";") | macro_definition }

function_call =  { identifier ~ "(" ~ arguments? ~ ")" }
argument      = _{ expression }
arguments     =  { argument ~ ("," ~ argument)? }

macro_definition        = {
    identifier ~ "->" ~ "!" ~ "{" ~ macro_body ~ "}"
}
macro_body              = {
    // "id" ~ ":" ~ string ~ "," ~ "parameters" ~ ":" ~ dictionary_type ~ ","?
    macro_action_id ~ "," ~ macro_action_parameters ~ ","?
}
macro_action_id         = { "id" ~ ":" ~ string }
macro_action_parameters = { "parameters" ~ ":" ~ dictionary_type }
macro_call              = {
    identifier ~ "!" ~ "(" ~ arguments ~ ")"
}

expression = _{ string }
identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

string = ${ "\"" ~ inner ~ "\"" }
inner  = @{ char* }
char   =  {
    !("\"" | "\\") ~ ANY
  | "\\" ~ ("\"" | "\\" | "/" | "b" | "f" | "n" | "r" | "t")
  | "\\" ~ ("u" ~ ASCII_HEX_DIGIT{4})
}

type                      = {
    "string"
  | "number"
  | "date"
  | "data"
  | "boolean"
  | "array" ~ array_type
  | "dictionary" ~ dictionary_type
}
array_type                = { "[" ~ (type ~ ("," ~ type)* ~ ","?)? ~ "]" }
dictionary_type           = {
    "{" ~ (dictionary_type_key_value ~ ("," ~ dictionary_type_key_value)* ~ ","?)? ~ "}"
}
dictionary_type_key_value = {
    identifier ~ ":" ~ type
}

// Whitespace
WHITESPACE = _{ WHITE_SPACE | NEWLINE | " " | "\t" }
COMMENT    = _{ "/*" ~ (!"*/" ~ ANY)* ~ "*/" | "//" }
